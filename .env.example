# ═══════════════════════════════════════════════════════════
# HUBEX Configuration — Copy to .env and adjust values
# ═══════════════════════════════════════════════════════════

# Environment: dev | staging | production
HUBEX_ENV=dev

# ── Database ──────────────────────────────────────────────
HUBEX_DATABASE_URL=postgresql+asyncpg://hubex:hubex@localhost:5432/hubex

# ── Redis (optional, enables caching + rate limiting) ─────
HUBEX_REDIS_URL=

# ── Security ──────────────────────────────────────────────
# IMPORTANT: Change this to a random string (≥32 chars) in production!
HUBEX_JWT_SECRET=change-me-now
HUBEX_JWT_ISSUER=hubex
HUBEX_JWT_EXP_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins. Empty = localhost defaults.
# Example: http://localhost:5173,https://your-domain.com
HUBEX_CORS_ORIGINS=

# ── Server ────────────────────────────────────────────────
HUBEX_HOST=127.0.0.1
HUBEX_PORT=8000

# ── Capabilities & Rate Limiting ──────────────────────────
HUBEX_CAPS_ENFORCE=true
HUBEX_RATE_LIMIT_ENABLED=true
HUBEX_CACHE_ENABLED=true

# ── Logging ───────────────────────────────────────────────
HUBEX_LOG_LEVEL=INFO
HUBEX_LOG_FORMAT=text

# ── Scaling ───────────────────────────────────────────────
HUBEX_HISTORY_RETENTION_DAYS=30
HUBEX_AUDIT_RETENTION_DAYS=90
HUBEX_TELEMETRY_QUEUE_ENABLED=false
HUBEX_AUTOMATION_CONCURRENCY=10
HUBEX_AUTOMATION_BATCH_SIZE=200
HUBEX_DB_POOL_SIZE=5
HUBEX_DB_MAX_OVERFLOW=20

# ── Edition & Soft Limits ─────────────────────────────────
# Edition: community | pro | enterprise
HUBEX_EDITION=community
HUBEX_MAX_USERS=5
HUBEX_MAX_DEVICES=50
HUBEX_MAX_API_KEYS=3
HUBEX_MAX_DASHBOARDS=10
HUBEX_MAX_AUTOMATIONS=20
HUBEX_MAX_CUSTOM_ENDPOINTS=5
HUBEX_UPGRADE_URL=https://hubextest.tech/pricing

# ── Refresh Tokens ────────────────────────────────────────
HUBEX_REFRESH_TOKEN_EXP_DAYS=30

# ── Email / SMTP (for notifications) ─────────────────────
HUBEX_SMTP_HOST=smtp.gmail.com
HUBEX_SMTP_PORT=587
HUBEX_SMTP_USER=
HUBEX_SMTP_PASSWORD=
HUBEX_SMTP_FROM=noreply@hubextest.tech
HUBEX_SMTP_TLS=true

# ── n8n Integration (optional) ───────────────────────────
# URL of n8n instance (enables integration card in frontend)
HUBEX_N8N_URL=http://localhost:5678

# ── Plugin Orchestrator (Sprint 3, optional) ─────────────
# Only needed if you enable the 'orchestrator' feature flag to install
# service plugins (n8n, Frigate, Ollama, ...). Connector plugins (Claude,
# OpenAI, ...) work without any of this — they just store API credentials.
#
# HUBEX_PORTAINER_URL is the URL the backend uses to reach Portainer over
# the compose network. For docker-compose.full.yml the service is reachable
# at https://hubex-portainer:9443 (TLS cert is self-signed, TLS verify is
# disabled in the client).
HUBEX_PORTAINER_URL=https://hubex-portainer:9443
HUBEX_PORTAINER_USER=admin

# Plaintext admin password used by the backend to log into Portainer.
# MUST match whatever hash you set as HUBEX_PORTAINER_ADMIN_HASH below.
# Leave empty to disable service-plugin orchestration.
HUBEX_PORTAINER_PASS=

# Bcrypt hash of HUBEX_PORTAINER_PASS, consumed by Portainer's
# `--admin-password` CLI flag on first boot. Generate with, e.g.:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YourPass', bcrypt.gensalt()).decode())"
# IMPORTANT: compose interpolates ${VAR}, so every literal '$' in the hash
# MUST be doubled to '$$' in this file (otherwise the middle of the hash
# gets swallowed as an empty variable reference).
# Example — the value below hashes to "example-do-not-use":
#   HUBEX_PORTAINER_ADMIN_HASH=$$2b$$12$$examplebcrypthashreplacemewithyourown
HUBEX_PORTAINER_ADMIN_HASH=
